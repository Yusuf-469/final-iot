# ==============================================
# Medical IoT Backend - Environment Variables
# ==============================================

# Server Configuration
NODE_ENV=development
PORT=3000

# Firebase Configuration (base64 encoded service account JSON)
FIREBASE_SERVICE_ACCOUNT_

# JWT Authentication - IMPORTANT: Change this in production!
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=7d


# Rate Limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend URL (for CORS)
FRONTEND_URL=https://final-iot-delta.vercel.app

# AI Insights - OpenRouter API
# ⚠️  WARNING: Never commit real API keys to repository!
# Set this in your Vercel dashboard environment variables only
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Vercel Environment (auto-set by Vercel when deployed)
# VERCEL_ENV=production
# VERCEL_URL=healthmonitor-zeta.vercel.app
